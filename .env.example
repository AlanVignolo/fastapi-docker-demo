# App
ENV=development
APP_NAME=fastapi-docker-demo
SECRET_KEY=change_me

# PostgreSQL (used by the db service and to build DATABASE_URL)
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo_password
POSTGRES_DB=fastapi_demo
DATABASE_URL=postgresql://demo:demo_password@db:5432/fastapi_demo

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL_SECONDS=60
